<?xml version="1.0" encoding="utf-8"?>
<!--
    Auto-backup rules applied on API level 23-30 via
    android:fullBackupContent in AndroidManifest.xml.

    Reference:
    https://developer.android.com/guide/topics/data/autobackup
-->
<full-backup-content>

    <!--
        Exclude the EncryptedSharedPreferences file that stores the user's
        contact data. The master key lives in the Android Keystore, which
        is NOT backed up, so restoring the encrypted blob on another device
        would just produce garbage. Shipping it off-device is also a
        privacy leak we don't need to take.
    -->
    <exclude domain="sharedpref" path="qrphone_secure_prefs.xml" />

    <!--
        Exclude the cached QR PNG that we create for sharing — it contains
        the full contact payload and has no business in cloud backups.
    -->
    <exclude domain="external" path="qr_code.png" />
    <exclude domain="root" path="cache/qr_code.png" />

</full-backup-content>
